# Server
SERVER_PORT=8081
SERVER_ENV=development

# Database (required)
POSTGRES_URL=postgres://datakeys:datakeys@localhost:5432/kyc?sslmode=disable

# SmileID — Afrique subsaharienne (principal)
SMILEID_API_KEY=
SMILEID_PARTNER_ID=
SMILEID_CALLBACK_URL=http://localhost:8081/v1/kyc/webhook/smileid
SMILEID_SANDBOX=true

# Youverify — Nigeria + Ghana (fallback)
YOUVERIFY_API_KEY=
YOUVERIFY_BASE_URL=
YOUVERIFY_SANDBOX=true

# SumSub — Maghreb + Afrique du Nord
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_BASE_URL=https://api.sumsub.com
SUMSUB_SANDBOX=true

# KYC settings
KYC_MAX_DOC_SIZE_MB=10
KYC_SESSION_TTL_SECONDS=3600
KYC_SCORE_THRESHOLD=0.70
KYC_DEFAULT_PROVIDER=smileid

# Compliance (BCEAO, NDPR, POPIA)
COMPLIANCE_CONSENT_REQUIRED=true
COMPLIANCE_RETENTION_DAYS=1825
COMPLIANCE_AUDIT_ENABLED=true

# Cleanup job
CLEANUP_INTERVAL=1h
CLEANUP_RETENTION_DAYS=1825

# Service version (appears in /health/ready)
SERVICE_VERSION=1.0.0

# Webhook IP allowlists (CIDR séparés par virgule, vide = désactivé en dev)
SMILEID_WEBHOOK_CIDRS=
SUMSUB_WEBHOOK_CIDRS=
